@model Ventas.Models.PedidoModel

@{
    ViewData["Title"] = "Edit";
}

<h1>Editar</h1>

<h4>Pedido</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Pedido_Id" />
            <div class="form-group">
                <label asp-for="FechaPedido" class="control-label"></label>
                <input asp-for="FechaPedido" class="form-control" />
                <span asp-validation-for="FechaPedido" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Total" class="control-label"></label>
                <input asp-for="Total" class="form-control" />
                <span asp-validation-for="Total" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="ClienteModelID" class="control-label">Cliente</label>
                <select asp-for="ClienteModelID" class="form-control" asp-items="ViewBag.ListaCliente"></select>
                <span asp-validation-for="ClienteModelID" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="EstadoPedidoModelId" class="control-label">Estado del Pedido</label>
                <select asp-for="EstadoPedidoModelId" class="form-control" asp-items="ViewBag.ListaEstado"></select>
                <span asp-validation-for="EstadoPedidoModelId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Atras</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
