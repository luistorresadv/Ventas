@model Ventas.Models.DetallePedidoModel

@{
    ViewData["Title"] = "Edit";
}

<h1>Editar</h1>

<h4>DetallePedidoModel</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Detalle_Id" />
            <div class="form-group">
                <label asp-for="Cantidad" class="control-label"></label>
                <input asp-for="Cantidad" class="form-control" />
                <span asp-validation-for="Cantidad" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Precio" class="control-label"></label>
                <input asp-for="Precio" class="form-control" />
                <span asp-validation-for="Precio" class="text-danger"></span>
            </div>
           
            <div class="form-group">
                <label asp-for="PedidoModelId" class="control-label">Código de Pedido</label>
                <select asp-for="PedidoModelId" class="form-control" asp-items="ViewBag.ListaPedidos"></select>
                <span asp-validation-for="PedidoModelId" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="ProductoModelId" class="control-label">Producto</label>
                <select asp-for="ProductoModelId" class="form-control" asp-items="ViewBag.ListaProductos"></select>
                <span asp-validation-for="ProductoModelId" class="text-danger"></span>
            </div>


            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Atrás</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
